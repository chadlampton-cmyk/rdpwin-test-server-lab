extends: default

rules:
  line-length:
    max: 140
    level: warning

  truthy: disable
  document-start: disable
  trailing-spaces: enable

  indentation:
    spaces: consistent
    indent-sequences: consistent

  comments:
    min-spaces-from-content: 1

  comments-indentation: false
  braces:
    max-spaces-inside: 1
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
